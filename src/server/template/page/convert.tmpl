{{define "content"}}
<section class="hero">
  <div class="container">
    <h1 class="hero-title">🔄 Unit Conversion</h1>
    <p class="hero-subtitle">
      42 tools for length, weight, temperature, currency, and color conversions
    </p>
  </div>
</section>

<section>
  <div class="container">
    <div class="category-grid">
      <a href="/convert/length" class="category-card">
        <div class="category-icon">📏</div>
        <h3 class="category-title">Length Converter</h3>
        <p class="category-description">Miles, kilometers, feet, meters, inches</p>
      </a>
      
      <a href="/convert/weight" class="category-card">
        <div class="category-icon">⚖️</div>
        <h3 class="category-title">Weight Converter</h3>
        <p class="category-description">Pounds, kilograms, ounces, grams</p>
      </a>
      
      <a href="/convert/temperature" class="category-card">
        <div class="category-icon">🌡️</div>
        <h3 class="category-title">Temperature Converter</h3>
        <p class="category-description">Celsius, Fahrenheit, Kelvin</p>
      </a>
      
      <a href="/convert/currency" class="category-card">
        <div class="category-icon">💱</div>
        <h3 class="category-title">Currency Converter</h3>
        <p class="category-description">Convert between world currencies</p>
      </a>
      
      <a href="/convert/color" class="category-card">
        <div class="category-icon">🎨</div>
        <h3 class="category-title">Color Converter</h3>
        <p class="category-description">RGB, HEX, HSL, HSV conversions</p>
      </a>
      
      <a href="/convert/data" class="category-card">
        <div class="category-icon">💾</div>
        <h3 class="category-title">Data Size Converter</h3>
        <p class="category-description">Bytes, KB, MB, GB, TB, bits</p>
      </a>
      
      <a href="/convert/speed" class="category-card">
        <div class="category-icon">⚡</div>
        <h3 class="category-title">Speed Converter</h3>
        <p class="category-description">MPH, KPH, knots, mach</p>
      </a>
      
      <a href="/convert/area" class="category-card">
        <div class="category-icon">◻️</div>
        <h3 class="category-title">Area Converter</h3>
        <p class="category-description">Square feet, meters, acres, hectares</p>
      </a>
      
      <a href="/convert/volume" class="category-card">
        <div class="category-icon">🏺</div>
        <h3 class="category-title">Volume Converter</h3>
        <p class="category-description">Gallons, liters, cups, milliliters</p>
      </a>
      
      <a href="/convert/time" class="category-card">
        <div class="category-icon">⏱️</div>
        <h3 class="category-title">Time Converter</h3>
        <p class="category-description">Seconds, minutes, hours, days</p>
      </a>
      
      <a href="/convert/pressure" class="category-card">
        <div class="category-icon">🌬️</div>
        <h3 class="category-title">Pressure Converter</h3>
        <p class="category-description">PSI, bar, pascal, atmosphere</p>
      </a>
      
      <a href="/convert/energy" class="category-card">
        <div class="category-icon">⚡</div>
        <h3 class="category-title">Energy Converter</h3>
        <p class="category-description">Joules, calories, BTU, kilowatt-hours</p>
      </a>
    </div>
    
    <p class="text-center text-muted mt-3">
      Showing 12 of 42 tools.
    </p>
  </div>
</section>
{{end}}
