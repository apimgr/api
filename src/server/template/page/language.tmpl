{{define "content"}}
<section class="hero">
  <div class="container">
    <h1 class="hero-title">📖 Language Tools</h1>
    <p class="hero-subtitle">
      48 tools for spell checking, dictionary, thesaurus, and language detection
    </p>
  </div>
</section>

<section>
  <div class="container">
    <div class="category-grid">
      <a href="/language/spell-check" class="category-card">
        <div class="category-icon">✍️</div>
        <h3 class="category-title">Spell Checker</h3>
        <p class="category-description">Check spelling and suggest corrections</p>
      </a>
      
      <a href="/language/dictionary" class="category-card">
        <div class="category-icon">📚</div>
        <h3 class="category-title">Dictionary</h3>
        <p class="category-description">Word definitions and meanings</p>
      </a>
      
      <a href="/language/thesaurus" class="category-card">
        <div class="category-icon">📖</div>
        <h3 class="category-title">Thesaurus</h3>
        <p class="category-description">Synonyms and antonyms</p>
      </a>
      
      <a href="/language/detect" class="category-card">
        <div class="category-icon">🌍</div>
        <h3 class="category-title">Language Detection</h3>
        <p class="category-description">Detect language of text</p>
      </a>
      
      <a href="/language/word-count" class="category-card">
        <div class="category-icon">🔢</div>
        <h3 class="category-title">Word Count</h3>
        <p class="category-description">Count words, characters, lines</p>
      </a>
      
      <a href="/language/reading-time" class="category-card">
        <div class="category-icon">⏱️</div>
        <h3 class="category-title">Reading Time</h3>
        <p class="category-description">Calculate reading time</p>
      </a>
      
      <a href="/language/sentiment" class="category-card">
        <div class="category-icon">😊</div>
        <h3 class="category-title">Sentiment Analysis</h3>
        <p class="category-description">Analyze text sentiment</p>
      </a>
      
      <a href="/language/keywords" class="category-card">
        <div class="category-icon">🔑</div>
        <h3 class="category-title">Keyword Extraction</h3>
        <p class="category-description">Extract keywords from text</p>
      </a>
      
      <a href="/language/translate" class="category-card">
        <div class="category-icon">🌐</div>
        <h3 class="category-title">Text Translation</h3>
        <p class="category-description">Translate between languages</p>
      </a>
      
      <a href="/language/phonetic" class="category-card">
        <div class="category-icon">🔊</div>
        <h3 class="category-title">Phonetic Encoding</h3>
        <p class="category-description">Soundex, Metaphone encoding</p>
      </a>
      
      <a href="/language/readability" class="category-card">
        <div class="category-icon">📊</div>
        <h3 class="category-title">Readability Score</h3>
        <p class="category-description">Flesch-Kincaid, Gunning Fog</p>
      </a>
      
      <a href="/language/grammar" class="category-card">
        <div class="category-icon">✏️</div>
        <h3 class="category-title">Grammar Check</h3>
        <p class="category-description">Basic grammar checking</p>
      </a>
    </div>
    
    <p class="text-center text-muted mt-3">
      Showing 12 of 48 tools.
    </p>
