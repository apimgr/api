{{define "content"}}
<section class="hero">
  <div class="container">
    <h1 class="hero-title">🖼️ Images</h1>
    <p class="hero-subtitle">
      68 tools for image resize, crop, filters, and manipulation
    </p>
  </div>
</section>

<section>
  <div class="container">
    <div class="category-grid">
      <a href="/image/resize" class="category-card">
        <div class="category-icon">📐</div>
        <h3 class="category-title">Resize Image</h3>
        <p class="category-description">Resize images to any dimension</p>
      </a>
      
      <a href="/image/crop" class="category-card">
        <div class="category-icon">✂️</div>
        <h3 class="category-title">Crop Image</h3>
        <p class="category-description">Crop images</p>
      </a>
      
      <a href="/image/filter" class="category-card">
        <div class="category-icon">🎨</div>
        <h3 class="category-title">Image Filters</h3>
        <p class="category-description">Grayscale, sepia, blur, sharpen</p>
      </a>
      
      <a href="/image/convert" class="category-card">
        <div class="category-icon">🔄</div>
        <h3 class="category-title">Format Convert</h3>
        <p class="category-description">Convert PNG, JPG, WEBP, GIF</p>
      </a>
      
      <a href="/image/qr" class="category-card">
        <div class="category-icon">📱</div>
        <h3 class="category-title">QR Code Image</h3>
        <p class="category-description">Generate QR code images</p>
      </a>
      
      <a href="/image/barcode" class="category-card">
        <div class="category-icon">〡〡〡</div>
        <h3 class="category-title">Barcode Image</h3>
        <p class="category-description">Generate barcode images</p>
      </a>
      
      <a href="/image/placeholder" class="category-card">
        <div class="category-icon">🖼️</div>
        <h3 class="category-title">Placeholder</h3>
        <p class="category-description">Generate placeholder images</p>
      </a>
      
      <a href="/image/avatar" class="category-card">
        <div class="category-icon">👤</div>
        <h3 class="category-title">Avatar</h3>
        <p class="category-description">Generate avatar from initials</p>
      </a>
      
      <a href="/image/identicon" class="category-card">
        <div class="category-icon">🔷</div>
        <h3 class="category-title">Identicon</h3>
        <p class="category-description">Generate identicons</p>
      </a>
      
      <a href="/image/metadata" class="category-card">
        <div class="category-icon">📋</div>
        <h3 class="category-title">Metadata Extract</h3>
        <p class="category-description">Extract EXIF data</p>
      </a>
      
      <a href="/image/optimize" class="category-card">
        <div class="category-icon">⚡</div>
        <h3 class="category-title">Optimize</h3>
        <p class="category-description">Compress and optimize</p>
      </a>
      
      <a href="/image/watermark" class="category-card">
        <div class="category-icon">©️</div>
        <h3 class="category-title">Watermark</h3>
        <p class="category-description">Add watermarks</p>
      </a>
    </div>
    
    <p class="text-center text-muted mt-3">
      Showing 12 of 68 tools.
    </p>
  </div>
</section>
