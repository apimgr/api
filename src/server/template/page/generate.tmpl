{{define "content"}}
<section class="hero">
  <div class="container">
    <h1 class="hero-title">✨ Generators</h1>
    <p class="hero-subtitle">
      76 tools for generating QR codes, barcodes, configs, avatars, and more
    </p>
  </div>
</section>

<section>
  <div class="container">
    <div class="category-grid">
      <a href="/generate/qr" class="category-card">
        <div class="category-icon">📱</div>
        <h3 class="category-title">QR Code</h3>
        <p class="category-description">Generate QR codes from text/URLs</p>
      </a>
      
      <a href="/generate/barcode" class="category-card">
        <div class="category-icon">〡〡〡</div>
        <h3 class="category-title">Barcode</h3>
        <p class="category-description">EAN, UPC, Code128, Code39</p>
      </a>
      
      <a href="/generate/avatar" class="category-card">
        <div class="category-icon">👤</div>
        <h3 class="category-title">Avatar</h3>
        <p class="category-description">Generate avatars from initials</p>
