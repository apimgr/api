      </a>
      
      <a href="/generate/identicon" class="category-card">
        <div class="category-icon">🔷</div>
        <h3 class="category-title">Identicon</h3>
        <p class="category-description">Generate identicons from hashes</p>
      </a>
      
      <a href="/generate/placeholder" class="category-card">
        <div class="category-icon">🖼️</div>
        <h3 class="category-title">Placeholder Image</h3>
        <p class="category-description">Generate placeholder images</p>
