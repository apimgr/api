{{define "content"}}
<section class="hero">
  <div class="container">
    <h1 class="hero-title">📚 Research Tools</h1>
    <p class="hero-subtitle">
      28 tools for content extraction, summarization, and citations
    </p>
  </div>
</section>

<section>
  <div class="container">
    <div class="category-grid">
      <a href="/research/metadata" class="category-card">
        <div class="category-icon">🔖</div>
        <h3 class="category-title">Web Metadata</h3>
        <p class="category-description">Extract page metadata</p>
      </a>
      
      <a href="/research/summarize" class="category-card">
        <div class="category-icon">📝</div>
        <h3 class="category-title">Content Summarizer</h3>
        <p class="category-description">Summarize long text</p>
      </a>
      
      <a href="/research/citation" class="category-card">
        <div class="category-icon">📖</div>
        <h3 class="category-title">Citation Generator</h3>
        <p class="category-description">APA, MLA, Chicago citations</p>
      </a>
      
      <a href="/research/bibtex" class="category-card">
        <div class="category-icon">📚</div>
        <h3 class="category-title">BibTeX Parser</h3>
        <p class="category-description">Parse and format BibTeX</p>
      </a>
      
      <a href="/research/doi" class="category-card">
        <div class="category-icon">🔗</div>
        <h3 class="category-title">DOI Resolver</h3>
        <p class="category-description">Resolve DOI to metadata</p>
      </a>
      
      <a href="/research/arxiv" class="category-card">
        <div class="category-icon">📄</div>
        <h3 class="category-title">arXiv Lookup</h3>
        <p class="category-description">Search arXiv papers</p>
      </a>
      
      <a href="/research/isbn" class="category-card">
        <div class="category-icon">📕</div>
        <h3 class="category-title">ISBN Lookup</h3>
        <p class="category-description">Book information from ISBN</p>
      </a>
      
      <a href="/research/pdf-extract" class="category-card">
        <div class="category-icon">📑</div>
        <h3 class="category-title">PDF Text Extract</h3>
        <p class="category-description">Extract text from PDFs</p>
      </a>
      
      <a href="/research/scraper" class="category-card">
        <div class="category-icon">🕷️</div>
        <h3 class="category-title">Web Scraper</h3>
        <p class="category-description">Extract data from websites</p>
      </a>
      
      <a href="/research/readability" class="category-card">
        <div class="category-icon">📖</div>
        <h3 class="category-title">Readability Mode</h3>
        <p class="category-description">Clean article extraction</p>
      </a>
      
      <a href="/research/outline" class="category-card">
        <div class="category-icon">📋</div>
        <h3 class="category-title">Outline Generator</h3>
        <p class="category-description">Generate document outlines</p>
      </a>
      
      <a href="/research/footnotes" class="category-card">
        <div class="category-icon">📌</div>
        <h3 class="category-title">Footnote Formatter</h3>
        <p class="category-description">Format footnotes and endnotes</p>
      </a>
    </div>
    
    <p class="text-center text-muted mt-3">
      Showing 12 of 28 tools.
    </p>
  </div>
